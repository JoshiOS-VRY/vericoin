# Build vericoind for the binarytest (DACE) test network.
# Built from the unified vericoin/ tree with CLIENT_IS_VERIUM=no.

FROM debian:bookworm-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        autotools-dev automake autoconf libtool pkg-config bsdmainutils \
        libssl-dev libevent-dev libboost-all-dev libdb5.3++-dev libminiupnpc-dev \
        libzmq3-dev libcurl4-openssl-dev libminizip-dev \
        git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY vericoin/ /src/vericoin/

WORKDIR /src/vericoin
RUN ./autogen.sh \
    && ./configure --disable-tests --disable-bench --without-gui --enable-vericoin \
                   --with-incompatible-bdb \
    && make -j$(nproc)

# --- runtime image ---------------------------------------------------------
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        libssl3 libevent-2.1-7 libboost-system1.74.0 libboost-filesystem1.74.0 \
        libboost-thread1.74.0 libboost-chrono1.74.0 libdb5.3++ libminiupnpc17 \
        libzmq5 libcurl4 libminizip1 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -d /home/dace -s /bin/bash dace
USER dace
WORKDIR /home/dace

COPY --from=builder /src/vericoin/src/vericoind /usr/local/bin/vericoind
COPY --from=builder /src/vericoin/src/vericoin-cli /usr/local/bin/vericoin-cli

# Datadir for the binarytest VRC chain is created on first run.
RUN mkdir -p /home/dace/.vericonomy/binarytest-vericoin

EXPOSE 41683 41684
ENTRYPOINT ["vericoind"]
